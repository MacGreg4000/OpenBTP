# ================================================
# Copier ce fichier en .env et remplir les valeurs
# NE PAS committer le fichier .env
# ================================================

# --- Base de données ---
DB_ROOT_PASSWORD=change_me_root_password
DB_PASSWORD=change_me_user_password

# --- Application ---
APP_PORT=3333
# Chemin du dossier uploads sur le NAS (laisser vide = ./uploads/ à côté du compose)
# UPLOADS_PATH=/volume1/docker/openbtp/uploads
# Chemin des sauvegardes BDD (laisser vide = ./backups/ à côté du compose)
# BACKUP_PATH=/volume1/docker/openbtp/backups
NEXTAUTH_URL=https://openbtp.secotech.synology.me
NEXTAUTH_SECRET=change_me_secret
NEXT_PUBLIC_APP_URL=https://openbtp.secotech.synology.me
NODE_ENV=production
LOG_LEVEL=info

# --- Service PDF (browserless - tourne sur le NAS hors Docker) ---
# "nas-host" est résolu vers le NAS grace a extra_hosts dans docker-compose.yml
PDF_SERVICE_URL=http://nas-host:3001
PDF_SERVICE_PROVIDER=browserless

# --- Ollama RAG (sur le NAS : binaire sur l’hôte OU conteneur avec -p 11434:11434) ---
# nas-host = passerelle vers l’hôte (voir extra_hosts dans docker-compose.yml)
OLLAMA_BASE_URL=http://nas-host:11434
OLLAMA_MODEL=phi3:mini
OLLAMA_EMBEDDING_MODEL=nomic-embed-text:latest
# Optionnel : limite de tokens générés (défaut 1000). Baisser (ex. 400) réduit le risque de 504 sur NAS lent.
# OLLAMA_MAX_TOKENS=400
# RAG : nombre max de chunks comparés par question (défaut 8000). Augmenter si beaucoup d’index.
# RAG_VECTOR_SCAN_LIMIT=8000
# RAG : ne pas appeler Ollama si la meilleure similarité est sous ce seuil (défaut 0.42) — évite des minutes d’attente.
# RAG_SKIP_LLM_BELOW_SIMILARITY=0.42

# --- Email (optionnel) ---
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
